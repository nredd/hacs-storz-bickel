#!/bin/bash

# script/spell-check: Check spelling without making changes
#
# Runs codespell in check-only mode without applying fixes. Useful for CI/CD
# and pre-commit validation. Configuration (ignore words, skip patterns) lives
# in [tool.codespell] in pyproject.toml.
#
# Usage:
#   ./script/spell-check
#
# Examples:
#   ./script/spell-check

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$SCRIPT_DIR/.."

# shellcheck source=script/.lib/output.sh
source "$SCRIPT_DIR/.lib/output.sh"

run_hook "spell-check" "pre"

log_header "Checking spelling with codespell"
uv run codespell \
    custom_components/ \
    card/src/ \
    card/test/ \
    README.md \
    CONTRIBUTING.md \
    DEPENDENCIES.md \
    script/ \
    tests/

# Clean up any accidental package installation from uv run
"$SCRIPT_DIR/clean" --minimal

run_hook "spell-check" "post"
log_success "Spell check completed"
