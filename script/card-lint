#!/bin/bash

# script/card-lint: Lint and format the card's TypeScript, applying fixes
#
# Runs Biome (lint + format, the card's analogue of Ruff) in write mode.
# For the check-only variant used by CI, see script/card-lint-check.
#
# Usage:
#   ./script/card-lint

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$SCRIPT_DIR/.."

# shellcheck source=script/.lib/output.sh
source "$SCRIPT_DIR/.lib/output.sh"
# shellcheck source=script/.lib/card.sh
source "$SCRIPT_DIR/.lib/card.sh"

require_bun

run_hook "card-lint" "pre"

log_header "Linting card TypeScript with Biome (fix mode)"
card_install
(cd card && bunx biome check --write .)

run_hook "card-lint" "post"
log_success "Card lint completed"
