#!/bin/bash

# script/smoke: Run the full CI Smoke suite locally
#
# Mirrors the "Smoke" job in .github/workflows/ci.yml exactly:
#   uv-sync        Sync the locked environment
#   lock-check     Verify the lock file is up to date
#   lint-check     Python (Ruff), YAML, Shell, Markdown linting
#   spell-check    Check spelling with codespell
#   ha-version-sync  HA release-train consistency
#   type-check     Python type checking (ty)
#   test           Run the test suite (pytest)
#
# Usage:
#   ./script/smoke

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$SCRIPT_DIR/.."

# shellcheck source=script/.lib/output.sh
source "$SCRIPT_DIR/.lib/output.sh"

run_hook "smoke" "pre"

"$SCRIPT_DIR/uv-sync"
echo ""
"$SCRIPT_DIR/lock-check"
echo ""
"$SCRIPT_DIR/lint-check"
echo ""
"$SCRIPT_DIR/spell-check"
echo ""
"$SCRIPT_DIR/ha-version-sync"
echo ""
"$SCRIPT_DIR/type-check"
echo ""
"$SCRIPT_DIR/test"

run_hook "smoke" "post"

log_success "Smoke passed"
