#!/bin/bash

# script/card-type-check: Type-check the card's TypeScript with tsc
#
# Bun transpiles but does not type-check; strict tsc --noEmit is the card's
# analogue of Astral ty for the Python side.
#
# Usage:
#   ./script/card-type-check

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$SCRIPT_DIR/.."

# shellcheck source=script/.lib/output.sh
source "$SCRIPT_DIR/.lib/output.sh"
# shellcheck source=script/.lib/card.sh
source "$SCRIPT_DIR/.lib/card.sh"

require_bun

run_hook "card-type-check" "pre"

log_header "Type-checking card TypeScript with tsc"
card_install
(cd card && bun run check)

run_hook "card-type-check" "post"
log_success "Card type check completed"
