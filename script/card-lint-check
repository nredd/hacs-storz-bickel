#!/bin/bash

# script/card-lint-check: Check card TypeScript lint/format without changes
#
# Runs Biome in CI mode (lint + format verification, no writes). To apply
# fixes locally, use script/card-lint.
#
# Usage:
#   ./script/card-lint-check

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$SCRIPT_DIR/.."

# shellcheck source=script/.lib/output.sh
source "$SCRIPT_DIR/.lib/output.sh"
# shellcheck source=script/.lib/card.sh
source "$SCRIPT_DIR/.lib/card.sh"

require_bun

run_hook "card-lint-check" "pre"

log_header "Checking card TypeScript with Biome"
card_install
(cd card && bunx biome ci .)

run_hook "card-lint-check" "post"
log_success "Card lint check completed"
